<?xml version="1.0" encoding="utf-8"?>
<!--
    Reglas de extracción de datos para Android 12+.
    Indica qué archivos pueden extraerse mediante Android Data Backup y Cloud Backup.

    Referencia: https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Excluir base de datos Room del backup en la nube -->
        <exclude domain="database" path="notas_app.db" />
        <exclude domain="database" path="notas_app.db-shm" />
        <exclude domain="database" path="notas_app.db-wal" />
        <exclude domain="sharedpref" path="encrypted_prefs.xml" />
    </cloud-backup>

    <device-transfer>
        <!-- Permitir transferencia de datos al cambiar de dispositivo -->
        <include domain="database" path="notas_app.db" />
    </device-transfer>
</data-extraction-rules>
